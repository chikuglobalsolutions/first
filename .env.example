# ── Database ───────────────────────────────────────────────
# Dev: SQLite (file). Prod: swap to Postgres (Neon/Supabase free tier)
DATABASE_URL="file:./dev.db"

# ── Auth (NextAuth) ─────────────────────────────────────────
# Production: set to your actual Netlify/Vercel URL
NEXTAUTH_URL="https://chikuglobalsolutions.com"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"

# ── Stripe ──────────────────────────────────────────────────
# Get from: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# PromptEmpire price IDs (already using direct Stripe links, these are backup)
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_BUSINESS_PRICE_ID="price_..."

# ── Email (Magic Link auth) ──────────────────────────────────
# Recommended: Resend.com (free tier, 100 emails/day)
# signup at resend.com → API Keys → create key → use below
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD="re_your_api_key_here"
EMAIL_FROM="noreply@chikuglobalsolutions.com"
